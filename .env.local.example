NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Fallback timezone — the live one is in the app_settings table, doctor-editable at /manage/settings.
NEXT_PUBLIC_DEFAULT_TIMEZONE=America/Chicago

# The two shared passwords. Anyone with the servant password becomes a servant.
# Anyone with the doctor password becomes a doctor (can manage list + settings + import).
APP_GATE_PASSWORD=your-servant-password-here
DOCTOR_PASSWORD=your-doctor-password-here
